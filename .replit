modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev & BASE_PATH=/ PORT=3000 pnpm --filter @workspace/brand-os run dev"
waitForPort = 3000

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 18565
externalPort = 3000

[[ports]]
localPort = 18566
externalPort = 3001

[[ports]]
localPort = 18567
externalPort = 3002

[userenv]

[userenv.shared]
JWT_SECRET = "6216399a5ff449bbb6e7de11adcb8661c32220e97008f588709de5e4913d75da54fb86ee3b76c00b4d587d9a82bb38596cd8186deb85bce7bba46ec67a6a8ace"
